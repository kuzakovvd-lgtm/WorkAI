WORKAI_ENV=dev
WORKAI_LOG__LEVEL=INFO
WORKAI_LOG__JSON=false
WORKAI_DB__DSN=postgresql://user:password@127.0.0.1:5432/workai
WORKAI_DB__MIN_SIZE=1
WORKAI_DB__MAX_SIZE=5
WORKAI_DB__TIMEOUT_SEC=10
WORKAI_DB__CONNECT_TIMEOUT_SEC=5
WORKAI_DB__LOCK_TIMEOUT_MS=2000

WORKAI_GSHEETS__ENABLED=false
WORKAI_GSHEETS__SPREADSHEET_ID=
WORKAI_GSHEETS__RANGES=Sheet1!A1:Z200
WORKAI_GSHEETS__SERVICE_ACCOUNT_FILE=
WORKAI_GSHEETS__SERVICE_ACCOUNT_JSON_B64=
WORKAI_GSHEETS__READ_ONLY=true
WORKAI_GSHEETS__REQUEST_TIMEOUT_SEC=30
WORKAI_GSHEETS__MAX_RETRIES=5
WORKAI_GSHEETS__BACKOFF_BASE_SEC=0.5
WORKAI_GSHEETS__BATCH_RANGES=20
WORKAI_GSHEETS__VALUE_RENDER_OPTION=FORMATTED_VALUE
WORKAI_GSHEETS__DATE_TIME_RENDER_OPTION=FORMATTED_STRING

WORKAI_PARSE__ENABLED=false
WORKAI_PARSE__HEADER_ROW_IDX=1
WORKAI_PARSE__EMPLOYEE_COL_IDX=1
WORKAI_PARSE__MAX_CELLS_PER_SHEET=20000
WORKAI_PARSE__DATE_FORMATS=%Y-%m-%d,%d.%m.%Y

WORKAI_NORMALIZE__ENABLED=false
WORKAI_NORMALIZE__EMPLOYEE_ALIASES_FILE=
WORKAI_NORMALIZE__FUZZY_ENABLED=false
WORKAI_NORMALIZE__FUZZY_THRESHOLD=90
WORKAI_NORMALIZE__TIME_PARSE_ENABLED=true
WORKAI_NORMALIZE__CATEGORY_RULES_FILE=
WORKAI_NORMALIZE__MAX_ROWS_PER_SHEET=200000
WORKAI_NORMALIZE__MAX_ERRORS_PER_SHEET=50

WORKAI_AUDIT__ENABLED=false
WORKAI_AUDIT__MAX_ITER=5
WORKAI_AUDIT__MAX_RPM=10
OPENAI_API_KEY=
OPENAI_MODEL_ANALYST=gpt-4o-mini
OPENAI_MODEL_FORENSIC=gpt-4o-mini
OPENAI_MODEL_REPORTER=gpt-4o
OPENAI_MAX_RETRIES=2

# API layer (Phase 8)
WORKAI_API_KEY=change-me
