[Unit]
Description=WorkAI v2 API (FastAPI)
After=network.target

[Service]
Type=simple
User=workai
Group=workai
WorkingDirectory=/opt/workai
EnvironmentFile=/etc/workai/secrets/db.env
EnvironmentFile=/etc/workai/secrets/api.env
EnvironmentFile=/etc/workai/secrets/workai.env
ExecStart=/opt/workai/.venv/bin/python /opt/workai/scripts/workai_api.py run --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
