[Unit]
Description=WorkAI v2 stale sweeper
After=network.target

[Service]
Type=oneshot
User=workai
Group=workai
WorkingDirectory=/opt/workai
EnvironmentFile=/etc/workai/secrets/db.env
EnvironmentFile=/etc/workai/secrets/workai.env
ExecStart=/opt/workai/.venv/bin/python /opt/workai/scripts/run_stale_sweeper.py --threshold-minutes 15
