[Unit]
Description=WorkAI v2 ingest run
After=network.target

[Service]
Type=oneshot
User=workai
Group=workai
WorkingDirectory=/opt/workai
EnvironmentFile=/etc/workai/secrets/db.env
EnvironmentFile=/etc/workai/secrets/workai.env
EnvironmentFile=-/etc/workai/secrets/google_sheets.env
ExecStart=/opt/workai/.venv/bin/python /opt/workai/scripts/workai_ingest.py run
