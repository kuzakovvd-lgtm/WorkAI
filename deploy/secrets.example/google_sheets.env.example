# Google Sheets credentials and source binding
WORKAI_GSHEETS__ENABLED=true
WORKAI_GSHEETS__SPREADSHEET_ID=replace-with-spreadsheet-id
WORKAI_GSHEETS__RANGES=Sheet1!A1:Z200,Sheet2!A1:Z200
WORKAI_GSHEETS__SERVICE_ACCOUNT_FILE=/etc/workai/google_sheets_sources.json
WORKAI_GSHEETS__SERVICE_ACCOUNT_JSON_B64=
